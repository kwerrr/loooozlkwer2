@dp.message(AdminActions.sending_broadcast)
async def admin_broadcast_process(message: types.Message, state: FSMContext):
    broadcast_text = message.text
    sent_count = 0
    failed_count = 0
    for user_id in db.users.keys():
        if user_id in db.banned_users:
            continue
        try:
            await bot.send_message(user_id, f"{hbold('📢 Рассылка от администрации:')}\n\n{broadcast_text}", parse_mode="HTML")
            sent_count += 1
            await asyncio.sleep(0.05)
        except Exception:
            failed_count += 1
    await message.answer(f"✅ Рассылка завершена!\nОтправлено: {sent_count}\nНе доставлено: {failed_count}")
    await state.clear()

