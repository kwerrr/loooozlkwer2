    try:
        parts = message.text.split()
        if len(parts) != 2:
            raise ValueError
        user_id = int(parts[0])
        amount = float(parts[1])
        user = db.get_user(user_id)
        db.update_user(user_id, total_turnover=user['total_turnover'] + amount)
        await message.answer(f"✅ Оборот пользователя {user_id} увеличен на {amount}")
    except Exception:
        await message.answer("❌ Неправильный формат. Используйте: ID СУММА")
    await state.clear()

