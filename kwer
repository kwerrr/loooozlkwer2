@dp.callback_query(lambda c: c.data.startswith('gift_sent_'))
async def process_gift_sent(callback: types.CallbackQuery):
    deal_id = callback.data.replace('gift_sent_', '')
    deal = db.get_deal(deal_id)
    if not deal:
        await callback.answer("❌ Сделка не найдена")
        return
    if deal['creator_id'] != callback.from_user.id:
        await callback.answer("❌ Вы не можете подтвердить отправку этой сделки")
        return
    if deal['status'] != DealStatus.PAID.value:
        await callback.answer("❌ Неверный статус сделки")
        return
    db.update_deal(deal_id, status=DealStatus.NFT_SENT.value, gift_sent_at=datetime.now().isoformat())
    if deal['buyer_id']:
        try:
            await callback.bot.send_message(
                deal['buyer_id'],
                f"{hbold('🎁 Продавец отправил подарок!')}\n\nID сделки: {hcode(deal_id)}\n"
                f"Продавец подтвердил передачу подарка гаранту.\nОжидайте проверки от поддержки.",
                parse_mode="HTML"
            )
        except Exception:
            pass
    await safe_edit(callback,
        f"{hbold('✅ Подтверждение получено!')}\n\nID сделки: {hcode(deal_id)}\n"
        f"Поддержка проверяет передачу подарка.\nОжидайте завершения сделки.",
        reply_markup=get_back_keyboard()
    )
    await callback.answer()
    asyncio.create_task(send_log_to_group(deal_id))
    seller = db.get_user(deal['creator_id'])
    buyer = db.get_user(deal['buyer_id']) if deal['buyer_id'] else None
    seller_mention = f"@{seller['username']}" if seller.get('username') else f"{seller.get('first_name','?')} (id:{deal['creator_id']})"
    buyer_mention = f"@{buyer['username']}" if buyer and buyer.get('username') else (f"{buyer.get('first_name','?')} (id:{deal['buyer_id']})" if buyer else 'нет')
    admin_text = (
        f"{hbold('🎁 Требуется проверка!')}\n\n"
        f"ID сделки: {hcode(deal_id)}\n"
        f"👤 Продавец: {seller_mention}\n"
        f"🛒 Покупатель: {buyer_mention}\n"
        f"🔗 Ссылка на NFT: {deal['description']}\n"
        f"💰 Сумма: {deal['amount']} {SUPPORTED_CURRENCIES[deal['currency']]}"
    )
    confirm_kb = InlineKeyboardMarkup(inline_keyboard=[[
        InlineKeyboardButton(text="✅ Завершить сделку", callback_data=f"admin_complete_{deal_id}")
    ]])
    for admin_id_str in ADMIN_IDS.split(','):
        try:
            await callback.bot.send_message(
                int(admin_id_str.strip()),
                admin_text,
                reply_markup=confirm_kb,
                parse_mode="HTML"
            )
        except Exception:
            pass

