@dp.message(AdminActions.ban_user)
async def admin_ban_process(message: types.Message, state: FSMContext):
    try:
        user_id = int(message.text.strip())
        if str(user_id) in ADMIN_IDS:
            await message.answer("❌ Нельзя забанить администратора!")
            await state.clear()
            return
        if db.ban_user(user_id):
            await message.answer(f"✅ Пользователь {user_id} успешно забанен!")
            try:
                await bot.send_message(user_id, f"🚫 Вы были забанены в боте.\nОбратитесь в поддержку: @{SUPPORT_USERNAME}")
            except Exception:
                pass
        else:
            await message.answer(f"❌ Пользователь {user_id} уже забанен или не найден")
    except ValueError:
        await message.answer("❌ Введите корректный ID пользователя")
    await state.clear()

